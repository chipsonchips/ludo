# Room server port (see server.ts).
# PORT=5100

# ChipsBank operator config — all optional. Without every value below, the
# server stays inert for real-money stakes: only stake 0 (Friendly) is
# accepted, and set_stake rejects anything nonzero with 'stake_unavailable'.

# base | celo (default celo)
# CHAIN=celo

# Defaults to the public RPC for the selected chain if unset.
# RPC_URL=https://forno.celo.org

# Deployed ChipsBank proxy address on the selected chain.
# CHIPSBANK_ADDRESS=0x...

# This game's registered ChipsBank operator key (owner must call
# registerGame(operatorAddress, dailyDebitLimit, dailyCreditLimit) first).
# LUDO_OPERATOR_KEY=0x...
