# WebSocket URL of the backend room server (Render deployment).
# If unset, the client falls back to ws://<hostname>:8787 (local dev).
VITE_WS_URL=wss://stellar-dice-server.onrender.com

# URL for the "back to hub" link.
VITE_HUB_URL=https://chipsonchips.com

# Optional comma-separated allowlist of hub origins the wallet bridge may
# pin. Leave unset to accept the first parent window that answers the
# handshake (the wallet is only ever reachable via the hub iframe anyway).
VITE_HUB_ORIGINS=https://chipsonchips.com,http://localhost:3000
